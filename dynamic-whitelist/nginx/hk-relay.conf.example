server {
    listen 443 ssl http2;
    server_name hk-relay.example.com;

    ssl_certificate /etc/letsencrypt/live/hk-relay.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hk-relay.example.com/privkey.pem;

    access_log /var/log/nginx/hk-relay.access.log;
    error_log /var/log/nginx/hk-relay.error.log warn;

    location = /healthz {
        proxy_pass http://127.0.0.1:9000/healthz;
    }

    location = /v1/allow {
        proxy_pass http://127.0.0.1:9000/v1/allow;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_connect_timeout 1s;
        proxy_read_timeout 3s;
        proxy_send_timeout 3s;
    }

    location / {
        return 404;
    }
}

