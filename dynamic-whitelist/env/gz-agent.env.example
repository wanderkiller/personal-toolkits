GZ_AGENT_HOST=10.0.0.2
GZ_AGENT_PORT=9001
GZ_AGENT_TOKEN=change-me-agent-token
PUBLIC_INTERFACE=auto
PROTECT_TCP=true
PROTECT_UDP=true
FIREWALL_ENABLED=true
DEBUG_ENDPOINTS=false
ALLOWLIST_MAX_IPS=6
